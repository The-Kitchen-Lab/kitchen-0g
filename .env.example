# ── 0G Network ───────────────────────────────────────────
# Galileo V3 Testnet
ZG_EVM_RPC=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16601
ZG_EXPLORER=https://chainscan-galileo.0g.ai
ZG_FAUCET=https://faucet.0g.ai

# Wallet private key (funded from faucet — testnet only)
ZG_PRIVATE_KEY=your_testnet_private_key_here

# ── 0G Storage ───────────────────────────────────────────
# Use either Standard (cheaper) or Turbo (faster)
ZG_STORAGE_INDEXER=https://indexer-storage-testnet-standard.0g.ai
# ZG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# ── 0G Compute ───────────────────────────────────────────
# Compute broker endpoint (check 0g.ai docs for current URL)
ZG_COMPUTE_ENDPOINT=https://compute-testnet.0g.ai
ZG_COMPUTE_MODEL=llama-3.1-8b-instruct

# ── 0G DA ────────────────────────────────────────────────
# DA node gRPC/REST endpoint
ZG_DA_ENDPOINT=https://da-testnet.0g.ai
ZG_DA_GRPC_PORT=34004
